function buildYearHTML(sel) {
  const isOlder = sel && !yearOptions.includes(sel);
  const sv = isOlder ? 'older' : sel;
  let h = '<option value="" disabled ' + (!sv ? 'selected' : '') + '>Select year</option>';
  yearOptions.forEach(y => { h += '<option value="' + y + '" ' + (sv===y?'selected':'') + '>' + y + '</option>'; });
  h += '<option value="older" ' + (sv==='older'?'selected':'') + '>My vehicle is older than 2016</option>';
  return h;
}

function buildColorOptionsHTML(bid) {
  return vehicleColors.map(c => {
    const ss = c.hex ? 'style="background:' + c.hex + ';"' : '';
    const sc = c.value==='other' ? 'color-picker__swatch color-picker__swatch--other' : 'color-picker__swatch';
    return '<div class="color-picker__option" data-value="' + c.value + '" data-label="' + c.label + '" data-hex="' + (c.hex||'') + '" onclick="selectColor(' + bid + ',this)"><span class="' + sc + '" ' + ss + '>' + (c.value==='other'?'?':'') + '</span><span class="color-picker__option-label">' + c.label + '</span></div>';
  }).join('');
}

function buildVehicleTypeSelector(bid, sel) {
  return '<div class="field-group"><label class="field-label">Vehicle Type <span class="required">*</span></label><div class="vtype-grid">' +
    vehicleTypes.map(vt => '<div class="vtype-card ' + (sel===vt.value?'selected':'') + '" data-vtype="' + vt.value + '" onclick="selectVehicleType(' + bid + ',\'' + vt.value + '\')"><div class="vtype-card__label">' + vt.label + '</div><div class="vtype-card__examples">' + vt.examples + '</div></div>').join('') +
    '</div><input type="hidden" class="vtype-hidden" name="v' + bid + '_type" value="' + (sel||'') + '" /></div>';
}

function buildConditionalFields(bid, vtv, p) {
  const vt = vehicleTypes.find(v => v.value === vtv);
  if (!vt) return '';
  let html = '';

  // "Other" type - special layout
  if (vt.isOther) {
    html += '<div class="field-group" style="margin-bottom:16px;"><label class="field-label">What are you looking to have wrapped or lettered? <span class="required">*</span></label><span class="field-helper">Describe the object, equipment, or vehicle &mdash; include dimensions if you know them.</span><textarea class="other-description" name="v' + bid + '_other_desc" placeholder="e.g. Industrial generator housing, 4ft x 6ft x 3ft..." rows="3">' + (p.otherDesc||'') + '</textarea></div>';
    html += '<div class="field-group"><label class="field-label">Upload Photos <span class="required">*</span></label><div class="photo-required-notice">&#128247; Photos are required so we can evaluate the surface and provide an accurate quote.</div><div class="file-upload file-upload--required" id="upload' + bid + '">' + icons.upload + '<p class="file-upload__text"><strong>Click to upload</strong> or drag and drop</p><input type="file" name="v' + bid + '_photos" multiple accept="image/*" onchange="showFileNames(this,\'upload' + bid + '\')" /><div class="file-names"></div></div></div>';
    return html;
  }

  const isLarge = ['box_truck','enclosed_trailer'].includes(vtv);
  const ex = typeExamples[vtv] || { make:'Ford', model:'Transit' };

  const browsing = p.browsing || false;
  html += '<div class="field-group"><label class="checkbox-option"><input type="checkbox" class="browsing-check" name="v' + bid + '_browsing" value="yes" ' + (browsing?'checked':'') + ' onchange="toggleBrowsing(' + bid + ')" /><span>I don\'t have this vehicle yet &mdash; just exploring options</span></label><div class="browsing-notice ' + (browsing?'visible':'') + '" id="browsingNotice_' + bid + '">No problem! We can still prepare a general estimate based on the vehicle type and project scope.</div></div>';

  const reqLabel = isLarge ? '<span class="optional">&mdash; not required</span>' : '<span class="required">*</span>';
  html += '<div class="field-row" style="margin-bottom:16px;"><div class="field-group"><label class="field-label">Year ' + reqLabel + '</label><select class="year-select">' + buildYearHTML(p.year) + '</select><input type="hidden" class="year-hidden" name="v' + bid + '_year" value="' + (p.year||'') + '" /><div class="older-vehicle-notice ' + (p.year&&!yearOptions.includes(p.year)?'visible':'') + '"><span>&#9888;&#65039;</span> For vehicles older than 2016, we\'d like to see the vehicle in person to evaluate paint condition before quoting.<input type="number" class="older-year-input" placeholder="Enter vehicle year" min="1970" max="2015" value="' + (p.year&&!yearOptions.includes(p.year)?p.year:'') + '" /></div></div><div class="field-group"><label class="field-label">Make ' + reqLabel + '</label><input type="text" name="v' + bid + '_make" placeholder="e.g. ' + ex.make + '" value="' + (p.make||'') + '" /></div></div>';
  html += '<div class="field-group" style="margin-bottom:16px;"><label class="field-label">Model ' + reqLabel + '</label><input type="text" name="v' + bid + '_model" placeholder="e.g. ' + ex.model + '" value="' + (p.model||'') + '" /></div>';

  vt.fields.forEach(fk => {
    const fd = conditionalOptions[fk];
    const val = p.conditionals ? (p.conditionals[fk]||'') : '';
    html += '<div class="field-group" style="margin-bottom:16px;"><label class="field-label">' + fd.label + ' <span class="required">*</span></label><select name="v' + bid + '_' + fk + '"><option value="" disabled ' + (!val?'selected':'') + '>Select ' + fd.label.toLowerCase() + '</option>' + fd.options.map(o => '<option value="' + o + '" ' + (val===o?'selected':'') + '>' + o + '</option>').join('') + '</select></div>';
  });

  // Color
  let tss='',tsi='',tlt='Select vehicle color',tlc='color-picker__trigger-label placeholder',ov=false;
  if(p.color){const m=vehicleColors.find(c=>c.value===p.color);if(m){tlt=m.label;tlc='color-picker__trigger-label';if(p.color==='other'){tss='background:linear-gradient(135deg,#E8E8E8 25%,#D0D0D0 25%,#D0D0D0 50%,#E8E8E8 50%,#E8E8E8 75%,#D0D0D0 75%);background-size:8px 8px;';tsi='<span style="font-size:12px;font-weight:700;color:#7D7D7D;">?</span>';ov=true;}else{tss='background:'+m.hex+';';}}}
  const hcv=p.color==='other'&&p.colorOther?'other:'+p.colorOther:(p.color||'');

  html += '<div class="field-group" style="margin-bottom:16px;"><label class="field-label">Vehicle Color</label><div class="color-picker" data-block="' + bid + '"><input type="hidden" class="color-picker__hidden" name="v' + bid + '_color" value="' + hcv + '" /><button type="button" class="color-picker__trigger" onclick="toggleColorDropdown(' + bid + ')"><span class="color-picker__trigger-swatch" style="' + tss + '">' + tsi + '</span><span class="' + tlc + '">' + tlt + '</span>' + icons.chevron + '</button><div class="color-picker__dropdown">' + buildColorOptionsHTML(bid) + '</div><input type="text" class="color-picker__other-input ' + (ov?'visible':'') + '" placeholder="Describe your vehicle color..." value="' + (p.colorOther||'') + '" /></div></div>';

  // Photos
  if (vt.photosRequired) {
    html += '<div class="field-group"><label class="field-label">Upload Vehicle Photos <span class="required">*</span></label><div class="photo-required-notice">&#128247; Photos are required for this vehicle type before we can provide a quote &mdash; it makes the process much smoother and faster.</div><div class="file-upload file-upload--required" id="upload' + bid + '">' + icons.upload + '<p class="file-upload__text"><strong>Click to upload</strong> or drag and drop</p><input type="file" name="v' + bid + '_photos" multiple accept="image/*" onchange="showFileNames(this,\'upload' + bid + '\')" /><div class="file-names"></div></div></div>';
  } else {
    html += '<div class="field-group"><label class="field-label">Upload Vehicle Photos</label><span class="field-helper">Optional but highly recommended &mdash; seeing your exact vehicle helps us provide the most accurate quote.</span><div class="file-upload" id="upload' + bid + '">' + icons.upload + '<p class="file-upload__text"><strong>Click to upload</strong> or drag and drop</p><input type="file" name="v' + bid + '_photos" multiple accept="image/*" onchange="showFileNames(this,\'upload' + bid + '\')" /><div class="file-names"></div></div></div>';
  }

  return html;
}

