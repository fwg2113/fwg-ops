//  COLOR PICKER
// -----------------------------------------------
function selectColor(bid,el) {
  const pk=el.closest('.color-picker'),tr=pk.querySelector('.color-picker__trigger'),dd=pk.querySelector('.color-picker__dropdown'),hd=pk.querySelector('.color-picker__hidden'),oi=pk.querySelector('.color-picker__other-input'),ts=tr.querySelector('.color-picker__trigger-swatch'),tl=tr.querySelector('.color-picker__trigger-label');
  const v=el.dataset.value,l=el.dataset.label,hex=el.dataset.hex;
  pk.querySelectorAll('.color-picker__option').forEach(function(o){o.classList.remove('selected');});el.classList.add('selected');
  tl.textContent=l;tl.classList.remove('placeholder');
  if(v==='other'){ts.style.background='linear-gradient(135deg,#E8E8E8 25%,#D0D0D0 25%,#D0D0D0 50%,#E8E8E8 50%,#E8E8E8 75%,#D0D0D0 75%)';ts.style.backgroundSize='8px 8px';ts.innerHTML='<span style="font-size:12px;font-weight:700;color:#7D7D7D;">?</span>';oi.classList.add('visible');hd.value='other';setTimeout(function(){oi.focus();},150);}
  else{ts.style.background=hex;ts.style.backgroundSize='';ts.innerHTML='';oi.classList.remove('visible');oi.value='';hd.value=v;}
  dd.classList.remove('open');tr.classList.remove('open');
}

function toggleColorDropdown(bid) {
  const pk=document.querySelector('.color-picker[data-block="'+bid+'"]'),tr=pk.querySelector('.color-picker__trigger'),dd=pk.querySelector('.color-picker__dropdown');
  document.querySelectorAll('.color-picker__dropdown.open').forEach(function(d){if(d!==dd){d.classList.remove('open');d.closest('.color-picker').querySelector('.color-picker__trigger').classList.remove('open');}});
  const o=dd.classList.toggle('open');tr.classList.toggle('open',o);
}

document.addEventListener('click',function(e){if(!e.target.closest('.color-picker')){document.querySelectorAll('.color-picker__dropdown.open').forEach(function(d){d.classList.remove('open');d.closest('.color-picker').querySelector('.color-picker__trigger').classList.remove('open');});}});
