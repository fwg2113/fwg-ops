function createVehicleBlock(prefill) {
  vehicleCounter++;
  const num = vehicleCounter;
  const totalBlocks = container.querySelectorAll('.vehicle-block').length + 1;
  const p = prefill || {vtype:'',year:'',make:'',model:'',color:'',colorOther:'',conditionals:{},browsing:false,otherDesc:''};

  const block = document.createElement('div');
  block.className = 'vehicle-block';
  block.dataset.id = num;

  let actionsHTML = '';
  if (totalBlocks > 1) actionsHTML += '<button type="button" class="btn-vehicle-action btn-copy" onclick="copyFromFirst(' + num + ')">' + icons.copy + ' Copy from Vehicle 1</button>';
  actionsHTML += '<button type="button" class="btn-vehicle-action btn-duplicate" onclick="duplicateVehicle(' + num + ')">' + icons.duplicate + ' Duplicate</button>';
  if (totalBlocks > 1) actionsHTML += '<button type="button" class="btn-vehicle-action btn-remove" onclick="removeVehicle(' + num + ')">' + icons.remove + ' Remove</button>';

  block.innerHTML =
    '<div class="vehicle-block__top-bar"><span class="vehicle-block__title">Vehicle <span class="vb-num">' + totalBlocks + '</span></span><div class="vehicle-block__actions">' + actionsHTML + '</div></div>' +
    buildVehicleTypeSelector(num, p.vtype) +
    '<div class="vtype-prompt" id="vtypePrompt_' + num + '" ' + (p.vtype?'style="display:none;"':'') + '><svg class="vtype-prompt__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg><div class="vtype-prompt__text">Select a vehicle type above to continue</div></div>' +
    '<div class="conditional-fields ' + (p.vtype?'visible':'') + '" id="cond_' + num + '">' + (p.vtype?buildConditionalFields(num,p.vtype,p):'') + '</div>';

  container.appendChild(block);
  if(p.color){const opt=block.querySelector('.color-picker__option[data-value="'+p.color+'"]');if(opt)opt.classList.add('selected');}
  updateVehicleNumbers();
  return num;
}

function selectVehicleType(bid, vtv) {
  const block = container.querySelector('.vehicle-block[data-id="' + bid + '"]');
  if(!block) return;
  block.querySelectorAll('.vtype-card').forEach(c=>c.classList.remove('selected'));
  block.querySelector('.vtype-card[data-vtype="' + vtv + '"]').classList.add('selected');
  block.querySelector('.vtype-hidden').value = vtv;
  const prompt = block.querySelector('#vtypePrompt_' + bid);
  if(prompt) prompt.style.display = 'none';
  const cc = block.querySelector('.conditional-fields');
  cc.innerHTML = buildConditionalFields(bid, vtv, {year:'',make:'',model:'',color:'',colorOther:'',conditionals:{},browsing:false,otherDesc:''});
  cc.classList.add('visible');
}

function toggleBrowsing(bid) {
  const block = container.querySelector('.vehicle-block[data-id="' + bid + '"]');
  if(!block) return;
  const cb = block.querySelector('.browsing-check');
  const notice = block.querySelector('#browsingNotice_' + bid);
  if(cb.checked) notice.classList.add('visible'); else notice.classList.remove('visible');
}

// -----------------------------------------------
//  GET/SET DATA
// -----------------------------------------------
function getVehicleData(bid) {
  const block = container.querySelector('.vehicle-block[data-id="' + bid + '"]');
  if(!block) return null;
  const vtype = (block.querySelector('.vtype-hidden')||{}).value||'';
  const vt = vehicleTypes.find(v=>v.value===vtype);

  // "Other" type
  if (vt && vt.isOther) {
    const descEl = block.querySelector('.other-description');
    return { vtype, otherDesc: descEl?descEl.value:'', isOther:true };
  }

  const yearEl = block.querySelector('.year-hidden');
  const makeEl = block.querySelector('[name$="_make"]');
  const modelEl = block.querySelector('[name$="_model"]');
  const colorEl = block.querySelector('.color-picker__hidden');
  const browseEl = block.querySelector('.browsing-check');
  let cv = colorEl?colorEl.value:'', co='';
  if(cv.startsWith('other:')){co=cv.substring(6);cv='other';}
  const conds = {};
  if(vt) vt.fields.forEach(fk=>{const s=block.querySelector('[name$="_'+fk+'"]');if(s)conds[fk]=s.value;});
  return {vtype, year:yearEl?yearEl.value:'', make:makeEl?makeEl.value:'', model:modelEl?modelEl.value:'', color:cv, colorOther:co, conditionals:conds, browsing:browseEl?browseEl.checked:false};
}

function getFirstVehicleData() { const f=container.querySelector('.vehicle-block'); return f?getVehicleData(f.dataset.id):null; }

function copyFromFirst(tid) {
  const data=getFirstVehicleData(); if(!data) return;
  const block=container.querySelector('.vehicle-block[data-id="'+tid+'"]'); if(!block) return;
  if(data.vtype){
    block.querySelectorAll('.vtype-card').forEach(c=>c.classList.remove('selected'));
    const card=block.querySelector('.vtype-card[data-vtype="'+data.vtype+'"]');if(card)card.classList.add('selected');
    block.querySelector('.vtype-hidden').value=data.vtype;
    const cc=block.querySelector('.conditional-fields');
    cc.innerHTML=buildConditionalFields(tid,data.vtype,data);cc.classList.add('visible');
    if(data.color){const opt=block.querySelector('.color-picker__option[data-value="'+data.color+'"]');if(opt)opt.classList.add('selected');}
  }
  showToast('Vehicle 1 info copied');
}

function duplicateVehicle(sid) {
  const data=getVehicleData(sid);if(!data)return;
  createVehicleBlock(data);
  const sb=container.querySelector('.vehicle-block[data-id="'+sid+'"]');
  showToast('Vehicle ' + (sb?sb.querySelector('.vb-num').textContent:'') + ' duplicated');
  container.lastElementChild.scrollIntoView({behavior:'smooth',block:'center'});
}

function removeVehicle(bid) {
  const blocks=container.querySelectorAll('.vehicle-block');if(blocks.length<=1)return;
  const block=container.querySelector('.vehicle-block[data-id="'+bid+'"]');if(!block)return;
  block.style.cssText='animation:none;opacity:0;transform:translateY(-8px);transition:all 0.2s ease;';
  setTimeout(function(){block.remove();updateVehicleNumbers();},200);
}

function updateVehicleNumbers() {
  const blocks=container.querySelectorAll('.vehicle-block');
  blocks.forEach(function(block,i){
    const n=i+1; block.querySelector('.vb-num').textContent=n;
    const ad=block.querySelector('.vehicle-block__actions'),bid=block.dataset.id;
    let h='';
    if(n>1)h+='<button type="button" class="btn-vehicle-action btn-copy" onclick="copyFromFirst('+bid+')">'+icons.copy+' Copy from Vehicle 1</button>';
    h+='<button type="button" class="btn-vehicle-action btn-duplicate" onclick="duplicateVehicle('+bid+')">'+icons.duplicate+' Duplicate</button>';
    if(n>1)h+='<button type="button" class="btn-vehicle-action btn-remove" onclick="removeVehicle('+bid+')">'+icons.remove+' Remove</button>';
    ad.innerHTML=h;
  });
  countDisplay.textContent=blocks.length;
}

