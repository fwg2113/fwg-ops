    </form>
  </div>

  <div class="modal-overlay" id="aiPolicyModal" onclick="cancelAiSelection(event)">
    <div class="modal" onclick="event.stopPropagation()">
      <div class="modal__header">
        <div class="modal__tag">AI artwork policy</div>
        <h3 class="modal__title">AI-generated mockups are inspiration only</h3>
      </div>
      <div class="modal__body">
        <p class="modal__intro">If your artwork was created with AI, please confirm you understand the following before continuing.</p>
        <div class="modal__points">
          <div class="modal__point">
            <span class="modal__point-num">1</span>
            <p class="modal__point-text">AI-generated artwork and mockups are treated as ideas and inspiration only. In most cases, we cannot match AI output exactly and final artwork will have differences.</p>
          </div>
          <div class="modal__point">
            <span class="modal__point-num">2</span>
            <p class="modal__point-text">AI images are not vector and are not production-ready. To use it professionally, we must rebuild it or vectorize it.</p>
          </div>
          <div class="modal__point">
            <span class="modal__point-num">3</span>
            <p class="modal__point-text">Our design service covers one direction, multiple options in the same theme and up to 3 rounds of revisions. Major direction changes after we start design are billed as additional design time.</p>
          </div>
          <div class="modal__point">
            <span class="modal__point-num">4</span>
            <p class="modal__point-text">To keep your brand consistent, we need your actual fonts, colors and logo files. If you do not have them, we will choose the closest professional matches.</p>
          </div>
        </div>
        <div class="modal__fine-print">Selecting &ldquo;I understand&rdquo; confirms you want us to interpret your AI concept and rebuild it into production-ready artwork.</div>
      </div>
      <div class="modal__footer">
        <button type="button" class="btn-modal-secondary" onclick="cancelAiFromModal()">Choose a different option</button>
        <button type="button" class="btn-modal-primary" onclick="acknowledgeAiPolicy()">I understand</button>
      </div>
    </div>
  </div>

  <div class="toast" id="toast"></div>

<script>
// ═══════════════════════════════════════════════
//  CONFIGURATION — Update these values
// ═══════════════════════════════════════════════
var FWG_CONFIG = {
  SUPABASE_URL:      '__YOUR_SUPABASE_URL__',      // e.g. https://xxxx.supabase.co
  SUPABASE_ANON_KEY: '__YOUR_SUPABASE_ANON_KEY__',
  API_URL:           '__YOUR_API_URL__',            // e.g. https://fwg-ops.vercel.app
  THANK_YOU_URL:     '/pages/thank-you',            // Shopify page redirect after submit
  STORAGE_BUCKET:    'form-uploads'
};

// -----------------------------------------------
//  STEPPER NAVIGATION
// -----------------------------------------------
const TOTAL_STEPS = 6;
let currentStep = 1;
const completedSteps = new Set();

function goToStep(target) {
  if (target < 1 || target > TOTAL_STEPS || target === currentStep) return;

  const isForward = target > currentStep;

  // Hard validate on forward navigation
  if (isForward) {
    // Must pass every step between current and target
    for (let s = currentStep; s < target; s++) {
      const errors = getStepErrors(s);
      if (errors.length > 0) {
        highlightErrors(s, errors);
        if (errors.includes('aiAcknowledge')) {
          showToast('AI artwork requires acknowledgment');
          openAiPolicyModal();
        } else {
          showToast('Please fill in all required fields');
        }
        return; // Block
      }
      completedSteps.add(s);
    }
  }

  // Going back is always allowed — mark current as completed if valid
  if (!isForward && getStepErrors(currentStep).length === 0) {
    completedSteps.add(currentStep);
  }

  switchCard(target);
}

function switchCard(target) {
  const currentCard = document.querySelector('.step-card[data-step="' + currentStep + '"]');
  if (currentCard) currentCard.classList.remove('active');

  // Build summary when landing on step 6
  if (target === 6) buildSummary();

  const targetCard = document.querySelector('.step-card[data-step="' + target + '"]');
  if (targetCard) {
    void targetCard.offsetWidth;
    targetCard.classList.add('active');
  }

  currentStep = target;
  updateStepper();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function getStepErrors(stepNum) {
  var errors = [];
  switch (stepNum) {
    case 1:
      if (!document.getElementById('businessName').value.trim()) errors.push('businessName');
      if (!document.getElementById('contactName').value.trim()) errors.push('contactName');
      if (!document.getElementById('email').value.trim()) errors.push('email');
      if (!document.getElementById('phone').value.trim()) errors.push('phone');
      if (!document.getElementById('contactMethodHidden').value) errors.push('contactMethod');
      break;
    case 2:
      var blocks = document.querySelectorAll('#vehicleBlocksContainer .vehicle-block');
      var anyType = false;
      blocks.forEach(function(b) { if (b.querySelector('.vtype-hidden') && b.querySelector('.vtype-hidden').value) anyType = true; });
      if (!anyType) errors.push('vehicleType');
      break;
    case 3:
      if (!document.getElementById('projectTypeHidden').value) errors.push('coverageType');
      break;
    case 4:
      if (!document.getElementById('artworkStatusHidden').value) errors.push('artworkStatus');
      else if (document.getElementById('artworkStatusHidden').value === 'ai_mockup' && document.getElementById('aiAcknowledged').value !== 'yes') errors.push('aiAcknowledge');
      break;
    case 5:
      if (!document.getElementById('timeline').value) errors.push('timeline');
      break;
    case 6:
      break; // Optional
  }
  return errors;
}

function highlightErrors(stepNum, errors) {
  // Clear previous errors
  document.querySelectorAll('.field-error').forEach(function(el) { el.classList.remove('field-error'); });

  var card = document.querySelector('.step-card[data-step="' + stepNum + '"]');
  if (!card) return;

  // Shake the card
  card.classList.remove('shake');
  void card.offsetWidth;
  card.classList.add('shake');

  errors.forEach(function(errKey) {
    switch(errKey) {
      case 'businessName': case 'contactName': case 'email': case 'phone':
        var el = document.getElementById(errKey);
        if (el) el.closest('.field-group').classList.add('field-error');
        break;
      case 'contactMethod':
        var cm = document.querySelector('.contact-method-group');
        if (cm) cm.closest('.field-group').classList.add('field-error');
        break;
      case 'vehicleType':
        var vg = document.querySelector('.vtype-grid');
        if (vg) vg.closest('.field-group').classList.add('field-error');
        break;
      case 'coverageType':
        var cg = document.querySelector('.coverage-type-group');
        if (cg) cg.closest('.field-group').classList.add('field-error');
        break;
      case 'artworkStatus':
        var ar = document.querySelector('.artwork-rows');
        if (ar) ar.closest('.field-group').classList.add('field-error');
        break;
      case 'aiAcknowledge':
        var ar2 = document.querySelector('.artwork-rows');
        if (ar2) ar2.closest('.field-group').classList.add('field-error');
        break;
      case 'timeline':
        var tl = document.getElementById('timeline');
        if (tl) tl.closest('.field-group').classList.add('field-error');
        break;
    }
  });
}

// Clear field errors on interaction
document.addEventListener('input', function() {
  document.querySelectorAll('.field-error').forEach(function(el) { el.classList.remove('field-error'); });
});
document.addEventListener('click', function(e) {
  if (e.target.closest('.contact-method-btn, .coverage-type-btn, .artwork-row, .vtype-card')) {
    document.querySelectorAll('.field-error').forEach(function(el) { el.classList.remove('field-error'); });
  }
});

function updateStepper() {
  document.querySelectorAll('.step-indicator').forEach(function(ind) {
    var step = parseInt(ind.dataset.step);
    ind.classList.remove('active', 'completed');

    if (step === currentStep) {
      ind.classList.add('active');
    } else if (completedSteps.has(step)) {
      ind.classList.add('completed');
    }
  });
}

// -----------------------------------------------
//  BUILD REVIEW SUMMARY
// -----------------------------------------------
const coverageLabels = { full_wrap:'Full Coverage Wrap', partial_wrap:'Partial Wrap', graphics_lettering:'Graphics & Lettering', not_sure:'Not Sure Yet' };
const artworkLabels = { fleet_match:'Fleet Match', print_ready:'Print-Ready Artwork', logo_vision:'Logo + Vision', logo_only:'Logo Only', from_scratch:'Start from Scratch', ai_mockup:'AI-Generated Mockup' };
const timelineLabels = { asap:'ASAP / As soon as possible', '30_days':'Within 30 days', '30_60_days':'30–60 days', '60_90_days':'60–90+ days', planning:'Just planning / gathering info' };
const budgetLabels = { under_1000:'Under $1,000', '1000_2500':'$1,000 – $2,500', '2500_5000':'$2,500 – $5,000', '5000_10000':'$5,000 – $10,000', '10000_plus':'$10,000+', not_sure:'Not sure yet' };

function esc(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

function summaryRow(label, value) {
  return '<div class="summary__row"><span class="summary__label">' + label + '</span><span class="summary__value">' + (value || '<span style="color:#B0B0B0;">—</span>') + '</span></div>';
}

function editBtn(step) {
  return '<button type="button" class="btn-edit" onclick="goToStep(' + step + ')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.83 2.83 0 114 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg> Edit</button>';
}

function sectionHeader(num, title, step) {
  return '<div class="summary__section-header"><div class="summary__section-title"><span class="summary__section-num">' + num + '</span> ' + title + '</div>' + editBtn(step) + '</div>';
}

function buildSummary() {
  var html = '';

  // 1. Contact Info
  html += '<div class="summary__section">';
  html += sectionHeader('01', 'Business Contact', 1);
  html += summaryRow('Business', esc(document.getElementById('businessName').value));
  html += summaryRow('Contact', esc(document.getElementById('contactName').value));
  html += summaryRow('Email', esc(document.getElementById('email').value));
  html += summaryRow('Phone', esc(document.getElementById('phone').value));
  var cm = document.getElementById('contactMethodHidden').value;
  var cmLabel = cm === 'email' ? 'Email' : cm === 'text' ? 'Text' : cm === 'call' ? 'Call' : '';
  html += summaryRow('Preferred', cmLabel);
  html += '</div>';

  // 2. Vehicles
  html += '<div class="summary__section">';
  html += sectionHeader('02', 'Vehicle Details', 2);
  var blocks = document.querySelectorAll('#vehicleBlocksContainer .vehicle-block');
  blocks.forEach(function(block, idx) {
    var bid = block.dataset.id;
    var data = getVehicleData(bid);
    if (!data) return;
    var vtObj = vehicleTypes.find(function(v) { return v.value === data.vtype; });
    var typeLabel = vtObj ? vtObj.label : '—';
    html += '<div class="summary__vehicle-card">';
    html += '<div class="summary__vehicle-label">Vehicle ' + (idx + 1) + '</div>';
    html += summaryRow('Type', esc(typeLabel));
    if (data.isOther) {
      html += summaryRow('Description', esc(data.otherDesc || '—'));
    } else {
      html += summaryRow('Year', esc(data.year || '—'));
      html += summaryRow('Make', esc(data.make || '—'));
      html += summaryRow('Model', esc(data.model || '—'));
      var colorVal = '—';
      if (data.color) {
        if (data.color === 'other' && data.colorOther) colorVal = data.colorOther;
        else { var cm2 = vehicleColors.find(function(c) { return c.value === data.color; }); if (cm2) colorVal = cm2.label; }
      }
      html += summaryRow('Color', esc(colorVal));
      if (vtObj && data.conditionals) {
        vtObj.fields.forEach(function(fk) {
          var fd = conditionalOptions[fk];
          if (fd && data.conditionals[fk]) html += summaryRow(fd.label, esc(data.conditionals[fk]));
        });
      }
      if (data.browsing) html += summaryRow('Note', 'Exploring options — don\'t have vehicle yet');
    }
    html += '</div>';
  });
  html += '</div>';

  // 3. Coverage Type
  html += '<div class="summary__section">';
  html += sectionHeader('03', 'Coverage Type', 3);
  var ct = document.getElementById('projectTypeHidden').value;
  html += summaryRow('Type', coverageLabels[ct] || '—');
  html += '</div>';

  // 4. Artwork
  html += '<div class="summary__section">';
  html += sectionHeader('04', 'Artwork & Design', 4);
  var aw = document.getElementById('artworkStatusHidden').value;
  html += summaryRow('Status', artworkLabels[aw] || '—');
  if (aw === 'ai_mockup') html += summaryRow('AI Policy', '<span style="color:var(--fwg-green);font-weight:600;">✓ Acknowledged</span>');
  var logoInput = document.querySelector('input[name="logo_file"]');
  if (logoInput && logoInput.files && logoInput.files.length > 0) {
    html += summaryRow('Logo File', esc(Array.from(logoInput.files).map(function(f) { return f.name; }).join(', ')));
  }
  html += '</div>';

  // 5. Timeline
  html += '<div class="summary__section">';
  html += sectionHeader('05', 'Timeline & Budget', 5);
  var tl = document.getElementById('timeline').value;
  html += summaryRow('Timeline', timelineLabels[tl] || '—');
  var bg = document.getElementById('budget').value;
  if (bg) html += summaryRow('Budget', budgetLabels[bg] || '—');
  html += '</div>';

  document.getElementById('summaryContainer').innerHTML = html;

  // Re-equalize since summary changes height
  setTimeout(equalizeCardHeights, 50);
}

// Equalize card heights after DOM ready
function equalizeCardHeights() {
  var cards = document.querySelectorAll('.step-card');
  var maxH = 0;
  // Temporarily show all cards to measure
  cards.forEach(function(c) { c.style.display = 'flex'; c.style.visibility = 'hidden'; c.style.position = 'absolute'; });
  cards.forEach(function(c) { if (c.offsetHeight > maxH) maxH = c.offsetHeight; });
  // Reset
  cards.forEach(function(c) { c.style.display = ''; c.style.visibility = ''; c.style.position = ''; });
  document.documentElement.style.setProperty('--card-min-height', maxH + 'px');
}
window.addEventListener('load', equalizeCardHeights);
window.addEventListener('resize', equalizeCardHeights);

// -----------------------------------------------
//  DATA
// -----------------------------------------------
let vehicleCounter = 0;
const container = document.getElementById('vehicleBlocksContainer');
const countDisplay = document.getElementById('vehicleCountDisplay');

const yearOptions = [];
for (let y = 2026; y >= 2016; y--) yearOptions.push(String(y));

const vehicleColors = [
  {value:'white',label:'White',hex:'#FFFFFF'},{value:'black',label:'Black',hex:'#1A1A1A'},
  {value:'gray',label:'Gray',hex:'#808080'},{value:'silver',label:'Silver',hex:'#C0C0C0'},
  {value:'blue',label:'Blue',hex:'#2B5EA7'},{value:'red',label:'Red',hex:'#C0392B'},
  {value:'brown',label:'Brown',hex:'#6B4226'},{value:'green',label:'Green',hex:'#2E7D32'},
  {value:'beige',label:'Beige / Tan',hex:'#C8B88A'},{value:'yellow',label:'Yellow',hex:'#F1C40F'},
  {value:'orange',label:'Orange',hex:'#E67E22'},{value:'other',label:'Other',hex:null},
];

const typeExamples = {
  coupe_sedan:     { make:'Honda',   model:'Civic' },
  minivan_suv:     { make:'Ford',    model:'Escape' },
  pickup:          { make:'Toyota',  model:'Tacoma' },
  compact_cargo_van:{ make:'Ford',   model:'Transit Connect' },
  box_truck:       { make:'Isuzu',   model:'NPR' },
  enclosed_trailer:{ make:'',        model:'6x12 Enclosed' },
  heavy_duty:      { make:'Freightliner', model:'MV607' },
  bus:             { make:'IC Bus',  model:'CE' },
};

const vehicleTypes = [
  { value:'coupe_sedan', label:'Coupe / Sedan', examples:'Civic, Camry, Model 3', fields:[], photosRequired:false, isOther:false },
  { value:'minivan_suv', label:'Minivans / SUV', examples:'Escape, CR-V, Sienna, Suburban', fields:[], photosRequired:false, isOther:false },
  { value:'pickup', label:'Pickup Truck', examples:'Tacoma, Silverado 2500, F-250', fields:['cab_size','bed_size'], photosRequired:false, isOther:false },
  { value:'compact_cargo_van', label:'Compact / Cargo Van', examples:'Transit Connect, ProMaster, Sprinter', fields:['roof_height','van_wheelbase'], photosRequired:false, isOther:false },
  { value:'box_truck', label:'Box Truck', examples:'NPR, E-Series Cutaway, Express Cutaway', fields:['box_length','box_height'], photosRequired:true, isOther:false },
  { value:'enclosed_trailer', label:'Enclosed Trailer', examples:'6x12 Enclosed, ST Cargo, 70SA', fields:['trailer_length','trailer_height','panel_fasteners'], photosRequired:true, isOther:false },
  { value:'heavy_duty', label:'Commercial / Heavy Duty Trucks', examples:'MV607, F-650, W900', fields:[], photosRequired:false, isOther:false },
  { value:'bus', label:'Buses', examples:'IC CE, MCI J4500, E-450 Cutaway', fields:[], photosRequired:false, isOther:false },
  { value:'other', label:'Other', examples:'Custom or specialty equipment', fields:[], photosRequired:true, isOther:true },
];

const conditionalOptions = {
  cab_size:  { label:'Cab Size', options:['Standard Cab','Extended Cab','Full Cab'] },
  bed_size:  { label:'Bed Size', options:['Short Bed','Standard Bed','Long Bed'] },
  van_wheelbase: { label:'Wheelbase', options:['Compact','Short','Standard','Extended'] },
  roof_height: { label:'Roof Height', options:['Compact','Low','Medium','High'] },
  box_length: { label:'Box Length', options:['10ft','12ft','14ft','16ft','20ft','24ft','26ft'] },
  box_height: { label:'Box Height', options:['7ft','8ft (most common)','8.5ft','9ft'] },
  trailer_length: { label:'Trailer Length', options:['6ft','7ft','8ft','9ft','10ft','11ft','12ft','13ft','14ft','15ft','16ft','17ft','18ft','19ft','20ft','21ft','22ft','23ft','24ft'] },
  trailer_height: { label:'Trailer Height', options:['7ft','8ft (most common)','8.5ft','9ft'] },
  panel_fasteners: { label:'Panel Fasteners', options:['Rivets','Screws'] },
