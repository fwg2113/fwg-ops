// -----------------------------------------------
function selectArtwork(row) {
  const value = row.dataset.value;

  // If selecting AI mockup, open policy modal instead of immediately selecting
  if (value === 'ai_mockup') {
    // Visually highlight but don't commit yet
    document.querySelectorAll('.artwork-row').forEach(r => r.classList.remove('selected'));
    row.classList.add('selected');
    openAiPolicyModal();
    return;
  }

  // Any other option: clear AI acknowledgment and select normally
  document.querySelectorAll('.artwork-row').forEach(r => r.classList.remove('selected'));
  row.classList.add('selected');
  document.getElementById('artworkStatusHidden').value = value;
  document.getElementById('aiAcknowledged').value = '';
}

// ── AI Policy Modal ──
function openAiPolicyModal() {
  document.getElementById('aiPolicyModal').classList.add('visible');
  document.body.style.overflow = 'hidden';
}

function closeAiPolicyModal() {
  document.getElementById('aiPolicyModal').classList.remove('visible');
  document.body.style.overflow = '';
}

function acknowledgeAiPolicy() {
  document.getElementById('artworkStatusHidden').value = 'ai_mockup';
  document.getElementById('aiAcknowledged').value = 'yes';
  closeAiPolicyModal();
  showToast('AI artwork policy acknowledged');
}

function cancelAiSelection(e) {
  // Clicked overlay background
  if (e.target === e.currentTarget) cancelAiFromModal();
}

function cancelAiFromModal() {
  closeAiPolicyModal();
  // Deselect AI option and clear hidden fields
  document.querySelectorAll('.artwork-row').forEach(r => r.classList.remove('selected'));
  document.getElementById('artworkStatusHidden').value = '';
  document.getElementById('aiAcknowledged').value = '';
}

// Escape key closes modal
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape' && document.getElementById('aiPolicyModal').classList.contains('visible')) {
    cancelAiFromModal();
  }
});

