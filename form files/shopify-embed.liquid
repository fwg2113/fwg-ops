// -----------------------------------------------
//  SUPABASE UPLOAD HELPERS
// -----------------------------------------------
function uploadFile(file, folder) {
  var timestamp = Date.now();
  var safeName = file.name.replace(/[^a-zA-Z0-9._-]/g, '_');
  var path = folder + '/' + timestamp + '_' + safeName;

  return fetch(
    FWG_CONFIG.SUPABASE_URL + '/storage/v1/object/' + FWG_CONFIG.STORAGE_BUCKET + '/' + path,
    {
      method: 'POST',
      headers: {
        'apikey': FWG_CONFIG.SUPABASE_ANON_KEY,
        'Authorization': 'Bearer ' + FWG_CONFIG.SUPABASE_ANON_KEY,
        'Content-Type': file.type,
        'x-upsert': 'true'
      },
      body: file
    }
  ).then(function(response) {
    if (!response.ok) {
      return response.text().then(function(t) { console.error('Upload failed:', file.name, t); return null; });
    }
    return FWG_CONFIG.SUPABASE_URL + '/storage/v1/object/public/' + FWG_CONFIG.STORAGE_BUCKET + '/' + path;
  });
}

function uploadFiles(fileInput, folder) {
  if (!fileInput || !fileInput.files || fileInput.files.length === 0) return Promise.resolve([]);
  var promises = [];
  for (var i = 0; i < fileInput.files.length; i++) {
    promises.push(uploadFile(fileInput.files[i], folder));
  }
  return Promise.all(promises).then(function(urls) {
    return urls.filter(function(u) { return u !== null; });
  });
}

// -----------------------------------------------
//  COLLECT FORM DATA
// -----------------------------------------------
function collectFormData() {
  var contact = {
    business_name: document.getElementById('businessName').value.trim(),
    contact_name: document.getElementById('contactName').value.trim(),
    email: document.getElementById('email').value.trim(),
    phone: document.getElementById('phone').value.trim(),
    contact_method: document.getElementById('contactMethodHidden').value
  };

  var vehicleBlocks = document.querySelectorAll('#vehicleBlocksContainer .vehicle-block');
  var vehicles = [];
  vehicleBlocks.forEach(function(block) {
    var bid = block.dataset.id;
    var data = getVehicleData(bid);
    if (!data || !data.vtype) return;
    var vtObj = vehicleTypes.find(function(v) { return v.value === data.vtype; });

    if (data.isOther) {
      vehicles.push({
        type: data.vtype,
        type_label: vtObj ? vtObj.label : 'Other',
        other_desc: data.otherDesc || '',
        is_other: true,
        _block_id: bid
      });
    } else {
      vehicles.push({
        type: data.vtype,
        type_label: vtObj ? vtObj.label : '',
        year: data.year || '',
        make: data.make || '',
        model: data.model || '',
        color: data.color || '',
        color_other: data.colorOther || '',
        browsing: data.browsing || false,
        conditionals: data.conditionals || {},
        is_other: false,
        _block_id: bid
      });
    }
  });

  var coverage_type = document.getElementById('projectTypeHidden').value;
  var artwork_status = document.getElementById('artworkStatusHidden').value;
  var ai_acknowledged = document.getElementById('aiAcknowledged').value === 'yes';
  var timeline = document.getElementById('timeline').value;
  var budgetEl = document.getElementById('budget');
  var budget = budgetEl ? budgetEl.value : '';
  var additionalEl = document.getElementById('additionalInfo');
  var additional_info = additionalEl ? additionalEl.value.trim() : '';

  return {
    business_name: contact.business_name,
    contact_name: contact.contact_name,
    email: contact.email,
    phone: contact.phone,
    contact_method: contact.contact_method,
    vehicles: vehicles,
    coverage_type: coverage_type,
    artwork_status: artwork_status,
    ai_acknowledged: ai_acknowledged,
    timeline: timeline,
    budget: budget || null,
    additional_info: additional_info || null,
    source_page: window.location.pathname,
    user_agent: navigator.userAgent
  };
}

// -----------------------------------------------
//  SUBMIT HANDLER
// -----------------------------------------------
document.getElementById('fwgInquiryForm').addEventListener('submit', function(e) {
  e.preventDefault();

  // Validate all steps
  for (var i = 1; i <= TOTAL_STEPS; i++) {
    var errors = getStepErrors(i);
    if (errors.length > 0) {
      switchCard(i);
      (function(step, errs) {
        setTimeout(function() { highlightErrors(step, errs); }, 50);
      })(i, errors);
      if (errors.includes('aiAcknowledge')) {
        showToast('AI artwork requires acknowledgment');
        openAiPolicyModal();
      } else {
        showToast('Please fill in all required fields');
      }
      return;
    }
  }

  // Collect data
  var formData = collectFormData();

  // Disable submit button, show loading
  var submitBtn = document.querySelector('.btn-submit, [type="submit"]');
  var originalText = submitBtn ? submitBtn.innerHTML : '';
  if (submitBtn) {
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span style="display:inline-flex;align-items:center;gap:8px;"><svg width="18" height="18" viewBox="0 0 24 24" style="animation:spin 1s linear infinite;"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" fill="none" stroke-dasharray="31 31" stroke-linecap="round"/></svg> Submitting...</span>';
  }

  // Generate a unique submission folder for file uploads
  var submissionId = Date.now() + '_' + Math.random().toString(36).substring(2, 8);
  var folder = 'submissions/' + submissionId;

  // Upload vehicle photos (sequential per vehicle)
  var uploadChain = Promise.resolve();
  formData.vehicles.forEach(function(v) {
    uploadChain = uploadChain.then(function() {
      var photoInput = document.querySelector('[name="v' + v._block_id + '_photos"]');
      return uploadFiles(photoInput, folder + '/vehicle_' + v._block_id).then(function(photoUrls) {
        v.photo_urls = photoUrls;
        delete v._block_id;
      });
    });
  });

  uploadChain
    .then(function() {
      // Upload logo files
      var logoInput = document.querySelector('input[name="logo_file"]');
      return uploadFiles(logoInput, folder + '/logos');
    })
    .then(function(logoUrls) {
      // POST to API endpoint (NOT directly to Supabase)
      var payload = {
        business_name: formData.business_name,
        contact_name: formData.contact_name,
        email: formData.email,
        phone: formData.phone,
        contact_method: formData.contact_method,
        vehicles: formData.vehicles,
        coverage_type: formData.coverage_type,
        artwork_status: formData.artwork_status,
        ai_acknowledged: formData.ai_acknowledged,
        logo_urls: logoUrls,
        timeline: formData.timeline,
        budget: formData.budget,
        additional_info: formData.additional_info,
        source_page: formData.source_page,
        user_agent: formData.user_agent
      };

      return fetch(FWG_CONFIG.API_URL + '/api/public/submit-form', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
    })
    .then(function(response) {
      if (!response.ok) {
        return response.text().then(function(t) { throw new Error('Submission failed: ' + t); });
      }
      // Success — redirect to thank you page
      showToast('Quote request submitted!');
      setTimeout(function() {
        window.location.href = FWG_CONFIG.THANK_YOU_URL;
      }, 800);
    })
    .catch(function(err) {
      console.error('Form submission error:', err);
      showToast('Something went wrong. Please try again or call us directly.');
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
      }
    });
});

