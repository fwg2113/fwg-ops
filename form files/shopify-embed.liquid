function selectCoverageType(btn) {
  document.querySelectorAll('.coverage-type-btn').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
  document.getElementById('projectTypeHidden').value = btn.dataset.value;

  const toggleBtn = document.getElementById('specsToggleBtn');
  const panel = document.getElementById('specsPanel');

  if (coverageSpecs[btn.dataset.value]) {
    toggleBtn.style.display = '';
    renderSpecsPanel(btn.dataset.value);
  } else {
    toggleBtn.style.display = 'none';
    panel.classList.remove('visible');
    panel.innerHTML = '';
    toggleBtn.classList.remove('open');
    document.getElementById('specsToggleLabel').textContent = 'Show Specs';
  }
}

function toggleSpecsPanel() {
  const panel = document.getElementById('specsPanel');
  const btn = document.getElementById('specsToggleBtn');
  const label = document.getElementById('specsToggleLabel');
  const isOpen = panel.classList.toggle('visible');
  btn.classList.toggle('open', isOpen);
  label.textContent = isOpen ? 'Hide Specs' : 'Show Specs';
}

function renderSpecsPanel(typeValue) {
  const panel = document.getElementById('specsPanel');
  const data = coverageSpecs[typeValue];
  if (!data) { panel.innerHTML = ''; return; }

  panel.innerHTML = data.specs.map(spec => {
    let dots = '';
    for (let i = 0; i < spec.total; i++) {
      const filled = i < spec.filled;
      const color = filled ? 'var(--fwg-red)' : '#D4D4D4';
      dots += '<span class="specs-panel__dot" style="background:' + color + ';"></span>';
    }
    return '<div class="specs-panel__row"><span class="specs-panel__label">' + spec.label + '</span><div class="specs-panel__dots">' + dots + '</div><span class="specs-panel__value">' + spec.filled + '/' + spec.total + '</span></div>';
  }).join('');
}

