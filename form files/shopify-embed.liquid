            <option value="2500_5000">$2,500 &ndash; $5,000</option>
            <option value="5000_10000">$5,000 &ndash; $10,000</option>
            <option value="10000_plus">$10,000+</option>
            <option value="not_sure">Not sure yet</option>
          </select>
        </div>
        <div class="step-card__footer">
          <button type="button" class="btn-nav btn-nav--back" onclick="goToStep(4)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg> Back</button>
          <button type="button" class="btn-nav btn-nav--continue" onclick="goToStep(6)">Continue <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></button>
        </div>
      </div>

      <!-- Step 6: Review & Submit -->
      <div class="step-card" data-step="6">
        <div class="step-card__header">
          <span class="step-card__number">06</span>
          <h2 class="step-card__title">Review &amp; Submit</h2>
        </div>
        <div class="summary" id="summaryContainer"></div>
        <div class="summary__divider"></div>
        <div class="field-group">
          <label class="field-label" for="additionalInfo">Anything else we should know?</label>
          <span class="field-helper">Brand requirements, special requests, or other notes.</span>
          <textarea id="additionalInfo" name="additional_info" placeholder="Share any details that might help us prepare your quote..."></textarea>
        </div>
        <div class="step-card__footer">
          <button type="button" class="btn-nav btn-nav--back" onclick="goToStep(5)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg> Back</button>
          <div style="text-align:center;">
            <button type="submit" class="btn-submit">Request Quote</button>
            <p class="submit-note">A member of our team will review your request and follow up after details are reviewed.</p>
