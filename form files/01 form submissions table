--  FILE STORAGE BUCKET
-- =============================================

-- Create storage bucket for form uploads
INSERT INTO storage.buckets (id, name, public, file_size_limit, allowed_mime_types)
VALUES (
  'form-uploads',
  'form-uploads',
  true,  -- public read so ops dashboard can view files
  10485760,  -- 10MB max per file
  ARRAY[
    'image/jpeg', 'image/png', 'image/gif', 'image/webp', 'image/heic',
    'application/pdf',
    'application/postscript',                    -- .ai, .eps
    'image/svg+xml',                             -- .svg
    'application/illustrator'                    -- .ai alternate
  ]
)
ON CONFLICT (id) DO NOTHING;

-- Storage policy: Anyone can upload (form submissions)
CREATE POLICY "Allow public uploads"
  ON storage.objects
  FOR INSERT
  TO anon
  WITH CHECK (bucket_id = 'form-uploads');

-- Storage policy: Anyone can read (public bucket)
CREATE POLICY "Allow public reads"
  ON storage.objects
  FOR SELECT
  TO anon
  USING (bucket_id = 'form-uploads');

-- Storage policy: Authenticated users can delete (ops cleanup)
CREATE POLICY "Authenticated can delete"
  ON storage.objects
  FOR DELETE
  TO authenticated
  USING (bucket_id = 'form-uploads');