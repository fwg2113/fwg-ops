{% layout none %}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  
  <title>{{ page.title }} | {{ shop.name }}</title>
  <meta name="description" content="Get a free estimate for commercial vehicle wraps. Full wraps, partial wraps, and custom lettering for cars, trucks, vans, and trailers.">
  
  <!-- Favicon -->
  <link rel="shortcut icon" href="{{ 'favicon.png' | asset_url }}" type="image/png">
  
  <!-- Preconnect for performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  
  <!-- Google Fonts (optional - matches brand) -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  
  <style>
    /* Reset and base styles */
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #f8fafc;
      color: #1e293b;
      line-height: 1.6;
      min-height: 100vh;
    }
    
    /* Header */
    .fwg-header {
      background: #1e293b;
      color: white;
      padding: 16px 20px;
      position: sticky;
      top: 0;
      z-index: 1000;
    }
    
    .fwg-header-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    
    .fwg-logo {
      display: flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
      color: white;
    }
    
    .fwg-logo-icon {
      width: 40px;
      height: 40px;
      background: linear-gradient(135deg, #f97316, #ea580c);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
    }
    
    .fwg-logo-text {
      font-size: 18px;
      font-weight: 700;
    }
    
    .fwg-header-contact {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    
    .fwg-header-phone {
      color: white;
      text-decoration: none;
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    
    .fwg-header-phone:hover {
      color: #f97316;
    }
    
    @media (max-width: 600px) {
      .fwg-header-contact span {
        display: none;
      }
    }
    
    /* Hero Section */
    .fwg-hero {
      background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
      color: white;
      padding: 48px 20px;
      text-align: center;
    }
    
    .fwg-hero h1 {
      font-size: 32px;
      font-weight: 700;
      margin-bottom: 12px;
    }
    
    .fwg-hero p {
      font-size: 18px;
      opacity: 0.9;
      max-width: 600px;
      margin: 0 auto;
    }
    
    @media (max-width: 600px) {
      .fwg-hero {
        padding: 32px 16px;
      }
      
      .fwg-hero h1 {
        font-size: 24px;
      }
      
      .fwg-hero p {
        font-size: 16px;
      }
    }
    
    /* Main Content */
    .fwg-main {
      padding: 32px 20px;
      max-width: 1000px;
      margin: 0 auto;
    }
    
    /* Trust Badges */
    .fwg-trust {
      display: flex;
      justify-content: center;
      gap: 32px;
      margin-bottom: 32px;
      flex-wrap: wrap;
    }
    
    .fwg-trust-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 14px;
      color: #64748b;
    }
    
    .fwg-trust-icon {
      color: #22c55e;
    }
    
    /* Footer */
    .fwg-footer {
      background: #1e293b;
      color: white;
      padding: 32px 20px;
      margin-top: 48px;
    }
    
    .fwg-footer-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 32px;
    }
    
    .fwg-footer h4 {
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 12px;
      color: #f97316;
    }
    
    .fwg-footer p, .fwg-footer a {
      font-size: 14px;
      color: #94a3b8;
      text-decoration: none;
      line-height: 1.8;
    }
    
    .fwg-footer a:hover {
      color: white;
    }
    
    .fwg-footer-bottom {
      max-width: 1200px;
      margin: 24px auto 0;
      padding-top: 24px;
      border-top: 1px solid #334155;
      text-align: center;
      font-size: 13px;
      color: #64748b;
    }
  </style>
  
  <!-- FWG Estimator CSS -->
  {{ 'fwg-wraps.css' | asset_url | stylesheet_tag }}
  
</head>
<body>
  
  <!-- Header -->
  <header class="fwg-header">
    <div class="fwg-header-inner">
      <a href="/" class="fwg-logo">
        <div class="fwg-logo-icon">🚐</div>
        <span class="fwg-logo-text">Frederick Window Graphics</span>
      </a>
      <div class="fwg-header-contact">
        <a href="tel:+12406933715" class="fwg-header-phone">
          📞 <span>(240) 693-3715</span>
        </a>
      </div>
    </div>
  </header>
  
  <!-- Hero -->
  <section class="fwg-hero">
    <h1>Commercial Vehicle Wrap Estimator</h1>
    <p>Get an instant estimate for your vehicle wrap project. Answer a few questions and we'll provide a price range.</p>
  </section>
  
  <!-- Trust Badges -->
  <div class="fwg-main">
    <div class="fwg-trust">
      <div class="fwg-trust-item">
        <span class="fwg-trust-icon">✓</span>
        <span>Free Estimates</span>
      </div>
      <div class="fwg-trust-item">
        <span class="fwg-trust-icon">✓</span>
        <span>Quality Materials</span>
      </div>
      <div class="fwg-trust-item">
        <span class="fwg-trust-icon">✓</span>
        <span>Professional Installation</span>
      </div>
      <div class="fwg-trust-item">
        <span class="fwg-trust-icon">✓</span>
        <span>Fleet Discounts</span>
      </div>
    </div>
    
    <!-- Estimator Container -->
    <div id="fwg-estimator"></div>
  </div>
  
  <!-- Footer -->
  <footer class="fwg-footer">
    <div class="fwg-footer-inner">
      <div>
        <h4>Contact Us</h4>
        <p>
          Frederick Window Graphics<br>
          5728 Buckeystown Pike Unit B<br>
          Frederick, MD 21704<br><br>
          <a href="tel:+12406933715">(240) 693-3715</a><br>
          <a href="mailto:info@frederickwraps.com">info@frederickwraps.com</a>
        </p>
      </div>
      <div>
        <h4>Services</h4>
        <p>
          <a href="#">Full Vehicle Wraps</a><br>
          <a href="#">Partial Wraps</a><br>
          <a href="#">Fleet Graphics</a><br>
          <a href="#">Vinyl Lettering</a><br>
          <a href="#">Custom Decals</a>
        </p>
      </div>
      <div>
        <h4>Hours</h4>
        <p>
          Monday - Friday: 8am - 5pm<br>
          Saturday - Sunday: Closed
        </p>
      </div>
    </div>
    <div class="fwg-footer-bottom">
      © {{ 'now' | date: '%Y' }} Frederick Window Graphics. All rights reserved.
    </div>
  </footer>
  
  <!-- FWG Estimator JS -->
  <script src="{{ 'fwg-wraps.js' | asset_url }}"></script>
  
</body>
</html>