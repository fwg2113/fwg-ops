<arg0>
<color>Natural</color>
<size>S</size>
<style>pc61</style>
</arg0>
<arg1>
<sanMarCustomerNumber>YourSanMarCustomerNumber</sanMarCustomerNumber>
<sanMarUserName>YourSanmar.comUsername</sanMarUserName>
<sanMarUserPassword>YourSanmar.comPassword</sanMarUserPassword>
</arg1>
</impl:getProductInfoByStyleColorSize>
</soapenv:Body>
