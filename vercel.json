{
  "crons": [
    {
      "path": "/api/purchase-orders/tracking-poll",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/conversions/batch-upload",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/noidle/weekly-reset",
      "schedule": "0 5 * * 1"
    }
  ],
  "functions": {
    "app/api/purchase-orders/tracking-poll/route.ts": {
      "maxDuration": 60
    },
    "app/api/image-enhancer/[action]/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "headers": [
    {
      "source": "/api/image-enhancer/(.*)",
      "headers": [
        {
          "key": "x-vercel-skip-toolbar",
          "value": "1"
        }
      ]
    }
  ]
}
