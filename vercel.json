{
  "functions": {
    "app/api/image-enhancer/[action]/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "headers": [
    {
      "source": "/api/image-enhancer/(.*)",
      "headers": [
        {
          "key": "x-vercel-skip-toolbar",
          "value": "1"
        }
      ]
    }
  ]
}
